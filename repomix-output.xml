        imagen.setPaciente(paciente);
        imagen.setFecha(Calendar.getInstance());
        imagen = repositoryImagen.saveAndFlush(imagen);
        if (imagen != null) {
            return "{\"response\" : \"file uploaded successfully : " + file.getOriginalFilename() + "\"}";
        }
        return null;
    }

